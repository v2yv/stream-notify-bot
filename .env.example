# ─── Telegram (user account, https://my.telegram.org/apps) ───
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
# Channel: @username or numeric id (-100...)
TELEGRAM_CHANNEL_ID=@mychannel
# Phone for first login only (+79991234567), then remove
TELEGRAM_PHONE=

# ─── Twitch ──────────────────────────────────────────────────
TWITCH_USERNAME=your_twitch_login

# ─── TikTok ──────────────────────────────────────────────────
TIKTOK_USERNAME=your_tiktok_username

# ─── General ─────────────────────────────────────────────────
CHECK_INTERVAL=30
